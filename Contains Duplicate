class Solution {
    public boolean containsDuplicate(int[] nums) {
        HashSet<Integer> num= new HashSet<Integer>();
        
       
       for(int i=0;i<nums.length;i++)
        {
           int currentnum=nums[i];
           if(num.contains(currentnum))
        {
            return true;
        }
        num.add(currentnum);
        }
        return false;
        
          
}
